pkgname=springcraft
pkgver=0.2.0
pkgrel=1
pkgdesc="Modern CLI scaffolder for Spring Boot projects - like Vite but for Spring"
arch=('x86_64' 'aarch64')
url="https://github.com/fmitesh007/springcraft-cli"
license=('MIT')
depends=()
makedepends=('pacman-contrib')
source_x86_64=("https://github.com/fmitesh007/springcraft-cli/releases/download/v${pkgver}/springcraft-linux")
source_aarch64=("https://github.com/fmitesh007/springcraft-cli/releases/download/v${pkgver}/springcraft-linux")
sha256sums_x86_64=('SKIP')
